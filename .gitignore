# Jekyll build artifacts
_site/
.jekyll-cache/
.jekyll-metadata
.sass-cache/

# Local Ruby/Bundler
Gemfile.lock
vendor/
.bundle/

# Local-only developer notes — kept on disk, never committed or published
README.md
_tools/where-things-live.md

# Secrets and credentials — never commit these. Push protection + the gitleaks
# workflow are the real safety net; this list just stops accidental staging.
.env
.env.*
*.pem
*.key
*.pfx
*.p12
*.pkcs12
*.keystore
id_rsa
id_dsa
id_ecdsa
id_ed25519
*.crt
credentials
credentials.json
secrets.json
.netrc
